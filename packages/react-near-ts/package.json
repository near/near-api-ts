{
  "name": "react-near-ts",
  "version": "0.1.0",
  "description": "TypeScript-first toolkit for integrating NEAR Protocol with your React application",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.90.21 <6",
    "react": ">=19.2.0 <20",
    "react-dom": ">=19.2.0 <20",
    "zod": ">=4.3.0 <5"
  },
  "dependencies": {
    "@hot-labs/near-connect": "^0.10.0",
    "near-api-ts": "workspace:*",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.90.21",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsdown": "0.20.3",
    "zod": "^4.3.6"
  },
  "types": "./dist/index.d.mts",
  "module": "./dist/index.mjs",
  "main": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "src",
    "types",
    "package.json",
    "LICENSE.md",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/near/near-api-ts.git",
    "directory": "packages/react-near-ts"
  },
  "keywords": [
    "near",
    "near-protocol",
    "near-api",
    "react",
    "react-query",
    "typescript",
    "web3",
    "blockchain"
  ],
  "author": {
    "name": "Volodymyr <eclipseeer> Bilyk",
    "email": "volodymyr@lantstool.dev"
  },
  "license": "MIT"
}
