{
  "name": "near-api-ts",
  "version": "0.10.0",
  "description": "Typescript library for interactions with Near Protocol in the browser or Node.js",
  "type": "module",
  "engines": {
    "node": ">=25"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "run": "tsx universal/index.ts",
    "typecheck": "tsc --noEmit",
    "sandbox:stop": "kill-port 4560",
    "test:all": "vitest run"
  },
  "peerDependencies": {
    "zod": ">=4.3.6 <5"
  },
  "dependencies": {
    "@near-js/jsonrpc-types": "^1.7.3",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0",
    "@noble/secp256k1": "^3.1.0",
    "@scure/base": "^2.2.0",
    "borsh": "^2.0.0",
    "lodash-es": "^4.18.1",
    "type-fest": "^5.6.0"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "zod": "^4.3.6"
  },
  "exports": {
    ".": {
      "browser": {
        "types": "./dist/browser/index.d.ts",
        "import": "./dist/browser/index.js",
        "default": "./dist/browser/index.js"
      },
      "node": {
        "types": "./dist/node/index.d.mts",
        "import": "./dist/node/index.mjs",
        "default": "./dist/node/index.mjs"
      },
      "default": {
        "types": "./dist/universal/index.d.ts",
        "import": "./dist/universal/index.js",
        "default": "./dist/universal/index.js"
      }
    },
    "./browser": {
      "types": "./dist/browser/index.d.ts",
      "import": "./dist/browser/index.js",
      "default": "./dist/browser/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.mts",
      "import": "./dist/node/index.mjs",
      "default": "./dist/node/index.mjs"
    }
  },
  "files": [
    "dist",
    "universal/src",
    "universal/types",
    "node/src",
    "node/types",
    "browser/src",
    "browser/types",
    "package.json",
    "README.md",
    "LICENSE.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/near/near-api-ts.git",
    "directory": "packages/near-api-ts"
  },
  "keywords": [
    "near",
    "near-protocol",
    "near-api",
    "typescript",
    "web3",
    "blockchain"
  ],
  "author": {
    "name": "Volodymyr <eclipseeer> Bilyk",
    "email": "volodymyr@lantstool.dev"
  },
  "license": "MIT"
}
