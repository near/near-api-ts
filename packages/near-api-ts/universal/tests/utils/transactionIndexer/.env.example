# Copy to `.env` and fill in. `.env` is gitignored.

# Bearer token for the FastNEAR archival RPC.
FASTNEAR_RPC_API_TOKEN=your-rpc-token-here

# Postgres connection (optional — defaults match docker-compose.yml).
# PGHOST=localhost
# PGPORT=5432
# PGUSER=indexer
# PGPASSWORD=indexer
# PGDATABASE=transaction_indexer
