    "sandbox:start": "tsx scripts/start-sandbox.ts",
    "sandbox:stop": "kill-port 4567"
  },
  "engines": {
    "node": ">=25"
  },
  "packageManager": "pnpm@10.33.2",
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^25.6.0",
    "kill-port": "^2.0.1",
    "near-sandbox": "0.2.0",
    "tsdown": "0.21.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
